<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="BaseTheme" parent="Theme.Material3.DynamicColors.Light.NoActionBar">

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar" tools:ignore="NewApi">true</item>
        <item name="android:colorBackground">?attr/colorSurface</item>

        <item name="textAppearanceTitleLarge">@style/YTTextAppearanceTitleLarge</item>
        <item name="textAppearanceBodyLarge">@style/YTTextAppearanceBodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/YTTextAppearanceBodyMedium</item>
        <item name="textAppearanceBodySmall">@style/YTTextAppearanceBodySmall</item>
        <item name="textAppearanceLabelSmall">@style/YTTextAppearanceLabelSmall</item>

        <item name="switchPreferenceCompatStyle">
            @style/Preference.SwitchPreferenceCompat.Material3
        </item>

        <item name="snackbarStyle">@style/snackBarStyle</item>

        <item name="loadingIndicatorStyle">@style/Widget.Material3.LoadingIndicator.Contained</item>

        <item name="materialAlertDialogTheme">@style/AlertDialogTheme</item>
    </style>

    <style name="SplashScreenTheme" parent="Theme.SplashScreen">

        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/BaseTheme</item>

    </style>

    <style name="Pure">

        <item name="android:colorBackground">?attr/colorSurface</item>
        <item name="colorSurface">?attr/colorSurface</item>
        <item name="colorSurfaceContainer">?attr/colorSurface</item>
        <item name="popupMenuBackground">@drawable/pure_theme_popup_menu_background</item>

    </style>

    <!-- YouTube-style light theme -->
    <style name="YouTubeLightTheme" parent="Theme.Material3.Light.NoActionBar">

        <item name="colorPrimary">@color/youtube_red</item>
        <item name="colorOnPrimary">@color/youtube_white</item>
        <item name="colorPrimaryContainer">#FFE0E0</item>
        <item name="colorOnPrimaryContainer">#8B0000</item>
        <item name="colorSecondary">#606060</item>
        <item name="colorOnSecondary">@color/youtube_white</item>
        <item name="colorSecondaryContainer">#E5E5E5</item>
        <item name="colorOnSecondaryContainer">#1A1A1A</item>
        <item name="colorSurface">@color/youtube_white</item>
        <item name="colorOnSurface">@color/youtube_text_primary</item>
        <item name="colorSurfaceVariant">@color/youtube_light_gray</item>
        <item name="colorOnSurfaceVariant">@color/youtube_text_secondary</item>
        <item name="colorOutline">#D9D9D9</item>

        <item name="android:statusBarColor">@color/youtube_white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/youtube_white</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:colorBackground">@color/youtube_white</item>

        <item name="textAppearanceTitleLarge">@style/YTTextAppearanceTitleLarge</item>
        <item name="textAppearanceBodyLarge">@style/YTTextAppearanceBodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/YTTextAppearanceBodyMedium</item>
        <item name="textAppearanceBodySmall">@style/YTTextAppearanceBodySmall</item>
        <item name="textAppearanceLabelSmall">@style/YTTextAppearanceLabelSmall</item>

        <item name="switchPreferenceCompatStyle">
            @style/Preference.SwitchPreferenceCompat.Material3
        </item>
        <item name="snackbarStyle">@style/snackBarStyle</item>
        <item name="loadingIndicatorStyle">@style/Widget.Material3.LoadingIndicator.Contained</item>
        <item name="materialAlertDialogTheme">@style/AlertDialogTheme</item>
    </style>

    <!-- LibreTube Red dark theme -->
    <style name="LibreTubeRedDarkTheme" parent="Theme.Material3.Dark.NoActionBar">

        <item name="colorPrimary">@color/youtube_red</item>
        <item name="colorOnPrimary">@color/youtube_white</item>
        <item name="colorPrimaryContainer">#8B0000</item>
        <item name="colorOnPrimaryContainer">#FFE0E0</item>
        <item name="colorSecondary">#AAAAAA</item>
        <item name="colorOnSecondary">@color/youtube_dark_surface</item>
        <item name="colorSecondaryContainer">#333333</item>
        <item name="colorOnSecondaryContainer">#E5E5E5</item>
        <item name="colorSurface">@color/youtube_dark_surface</item>
        <item name="colorOnSurface">@color/youtube_text_primary_dark</item>
        <item name="colorSurfaceVariant">@color/youtube_dark_surface2</item>
        <item name="colorOnSurfaceVariant">@color/youtube_text_secondary_dark</item>
        <item name="colorOutline">#333333</item>

        <item name="android:statusBarColor">@color/youtube_dark_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/youtube_dark_surface</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:colorBackground">@color/youtube_dark_surface</item>

        <item name="textAppearanceTitleLarge">@style/YTTextAppearanceTitleLarge</item>
        <item name="textAppearanceBodyLarge">@style/YTTextAppearanceBodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/YTTextAppearanceBodyMedium</item>
        <item name="textAppearanceBodySmall">@style/YTTextAppearanceBodySmall</item>
        <item name="textAppearanceLabelSmall">@style/YTTextAppearanceLabelSmall</item>

        <item name="switchPreferenceCompatStyle">
            @style/Preference.SwitchPreferenceCompat.Material3
        </item>
        <item name="snackbarStyle">@style/snackBarStyle</item>
        <item name="loadingIndicatorStyle">@style/Widget.Material3.LoadingIndicator.Contained</item>
        <item name="materialAlertDialogTheme">@style/AlertDialogTheme</item>
    </style>

    <style name="DialogActivity">

        <item name="android:colorBackground">?attr/colorBackgroundFloating</item>
        <item name="android:colorBackgroundCacheHint">@null</item>

        <item name="android:windowFrame">@null</item>
        <item name="android:windowTitleStyle">@style/RtlOverlay.DialogWindowTitle.AppCompat</item>
        <item name="android:windowTitleBackgroundStyle">@style/Base.DialogWindowTitleBackground.AppCompat</item>
        <item name="android:windowBackground">@drawable/abc_dialog_material_background</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@style/Animation.AppCompat.Dialog</item>
        <item name="android:windowSoftInputMode">stateUnspecified|adjustPan</item>

        <item name="windowActionBar">false</item>
        <item name="windowActionModeOverlay">true</item>

        <item name="listPreferredItemPaddingLeft">24dip</item>
        <item name="listPreferredItemPaddingRight">24dip</item>

        <item name="android:listDivider">@null</item>

        <item name="android:buttonBarStyle">@style/Widget.AppCompat.ButtonBar.AlertDialog</item>
        <item name="android:borderlessButtonStyle">@style/Widget.AppCompat.Button.Borderless</item>
        <item name="android:windowCloseOnTouchOutside">true</item>

    </style>

</resources>
