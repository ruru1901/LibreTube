<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="BaseTheme" parent="Theme.Material3.DynamicColors.Dark.NoActionBar">

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar" tools:ignore="NewApi">false</item>
        <item name="android:colorBackground">?attr/colorSurface</item>

        <item name="colorSurface">@color/yt_dark_surface</item>
        <item name="colorOnSurface">@color/yt_dark_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/yt_dark_on_surface_variant</item>
        <item name="colorOutlineVariant">@color/yt_dark_outline_variant</item>
        <item name="colorPrimary">@color/yt_dark_primary_fallback</item>

        <item name="textAppearanceTitleLarge">@style/YTTextAppearanceTitleLarge</item>
        <item name="textAppearanceBodyLarge">@style/YTTextAppearanceBodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/YTTextAppearanceBodyMedium</item>
        <item name="textAppearanceBodySmall">@style/YTTextAppearanceBodySmall</item>
        <item name="textAppearanceLabelSmall">@style/YTTextAppearanceLabelSmall</item>

        <item name="switchPreferenceCompatStyle">
            @style/Preference.SwitchPreferenceCompat.Material3
        </item>

        <item name="snackbarStyle">@style/snackBarStyle</item>

        <item name="loadingIndicatorStyle">@style/Widget.Material3.LoadingIndicator.Contained</item>

        <item name="materialAlertDialogTheme">@style/AlertDialogTheme</item>
    </style>

    <style name="StartupTheme" parent="Theme.SplashScreen">

        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/BaseTheme</item>

    </style>



    <style name="Pure">

        <item name="android:colorBackground">?attr/colorSurface</item>
        <item name="colorSurface">?attr/colorSurface</item>
        <item name="colorSurfaceContainer">?attr/colorSurface</item>
        <item name="popupMenuBackground">@drawable/pure_theme_popup_menu_background</item>

    </style>

</resources>